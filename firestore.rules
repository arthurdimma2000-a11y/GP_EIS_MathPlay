rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      return signedIn()
        && exists(/databases/$(database)/documents/teacherProfiles/$(request.auth.uid));
    }

    function isParent() {
      return signedIn()
        && exists(/databases/$(database)/documents/parentProfiles/$(request.auth.uid));
    }

    function isStudent() {
      return signedIn()
        && request.auth.token.role == "student";
    }

    function parentChildId() {
      return isParent()
        ? get(/databases/$(database)/documents/parentProfiles/$(request.auth.uid)).data.childStudentId
        : "";
    }

    match /teacherProfiles/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /parentProfiles/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /studentAccounts/{studentId} {
      allow create: if isTeacher()
        && request.resource.data.teacherUid == request.auth.uid;

      allow update: if isTeacher()
        && resource.data.teacherUid == request.auth.uid
        && request.resource.data.teacherUid == request.auth.uid;

      allow read: if (isTeacher() && resource.data.teacherUid == request.auth.uid)
        || (isParent() && resource.data.studentId == parentChildId())
        || (isStudent() && resource.data.studentId == request.auth.token.studentId);
    }

    match /results/{resultId} {
      allow create, update: if (isStudent()
          && request.resource.data.studentId == request.auth.token.studentId
          && request.resource.data.classId == request.auth.token.classId)
        || (isTeacher()
          && request.resource.data.teacherUid == request.auth.uid);

      allow read: if (isTeacher() && resource.data.teacherUid == request.auth.uid)
        || (isParent() && resource.data.studentId == parentChildId())
        || (isStudent() && resource.data.studentId == request.auth.token.studentId);
    }

    match /dailySummaries/{summaryId} {
      allow create, update: if (isStudent()
          && request.resource.data.studentId == request.auth.token.studentId
          && request.resource.data.classId == request.auth.token.classId)
        || (isTeacher()
          && request.resource.data.teacherUid == request.auth.uid);

      allow read: if (isTeacher() && resource.data.teacherUid == request.auth.uid)
        || (isParent() && resource.data.studentId == parentChildId())
        || (isStudent() && resource.data.studentId == request.auth.token.studentId);
    }
  }
}

